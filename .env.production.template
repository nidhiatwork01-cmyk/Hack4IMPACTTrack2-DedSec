## Frontend environment template (production build)
## Copy this file to .env.production at repo root during deployment.

# Full backend URL used by frontend in production.
# Example: https://api.your-domain.com
REACT_APP_API_BASE_URL=

# Optional if your deployment still relies on local proxy semantics.
REACT_APP_BACKEND_PORT=8000

# Razorpay publishable key for production checkout.
REACT_APP_RAZORPAY_KEY=
