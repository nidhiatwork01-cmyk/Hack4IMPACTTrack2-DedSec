## Frontend environment template (development)
## Copy this file to .env at repo root.

# Optional explicit backend URL. Leave empty to use CRA proxy (/api and /uploads).
REACT_APP_API_BASE_URL=

# Local backend port used by src/setupProxy.js (defaults to 8000 if omitted).
REACT_APP_BACKEND_PORT=8000

# Optional Razorpay public key (frontend-safe publishable key only).
REACT_APP_RAZORPAY_KEY=
